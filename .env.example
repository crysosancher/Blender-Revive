# WhatsApp Bot Configuration

# Port for optional health checks/services (default: 3000)
PORT=3000

# WhatsApp session identifier
SESSION_ID=blender-revive-session

# Bot command prefix
BOT_PREFIX=/

# Bot's own phone number (to prevent tagging itself in tagall/tagunreg commands)
BOT_NUMBER=


# MongoDB Database Configuration (MongoDB Atlas Cloud Storage)
# Replace <username>, <password>, and <cluster-name> with your Atlas cluster credentials.
MONGO_URI=
MONGO_DB_NAME=whatsapp_bot

# Redis Configuration (Local Docker)
# For local Docker setup: localhost
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Developer Credentials
DEVELOPER_NUMBER=

# Gemini API Configuration
GEMINI_API_KEY=

